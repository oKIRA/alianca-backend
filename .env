# Environment Variables
NODE_ENV=development
PORT=3000

# Firebase Admin SDK (Service Account)
# Obtenha em: Firebase Console → Configurações do projeto → Contas de serviço → Gerar nova chave privada
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# Firebase Web API Key (usado para login via REST)
# Obtenha em: Firebase Console → Configurações do projeto → Geral → Chave de API da Web
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# CORS
FRONTEND_URL=http://localhost:5175

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
